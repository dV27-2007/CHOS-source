# Minimal i3 config for David
set $mod Mod1
font pango:monospace 9

exec --no-startup-id xinput set-prop 13 "libinput Tapping Enabled" 1
exec --no-startup-id xinput set-prop 13 "libinput Natural Scrolling Enabled" 1
exec --no-startup-id xinput set-prop 13 "libinput Click Method Enabled" 0 1
exec --no-startup-id xinput set-prop 13 "libinput Accel Speed" 0.4

# Terminal
bindsym $mod+Return exec kitty

# App launcher

# Close window
bindsym $mod+q kill
bindsym $mod+Shift+q kill

# Alt+Tab window switching
bindsym $mod+Tab focus next
bindsym $mod+Shift+Tab focus prev

# Focus windows
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move windows
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Split
bindsym $mod+b split h
bindsym $mod+v split v

# Layouts
bindsym $mod+e layout toggle split
bindsym $mod+w layout tabbed
bindsym $mod+s layout stacking
bindsym $mod+f fullscreen toggle

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Resize mode
mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt

    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym $mod+r mode "default"
}
# bindsym $mod+r mode "resize"

# Reload / restart / exit
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-msg exit"

# Mouse support
floating_modifier $mod
tiling_drag modifier titlebar

# Two monitors
exec --no-startup-id xrandr --output eDP-1 --primary --auto --output HDMI-1-0 --auto --right-of eDP-1
exec --no-startup-id picom --backend glx

# Network tray
exec --no-startup-id dbus-update-activation-environment --systemd DISPLAY XAUTHORITY
exec --no-startup-id nm-applet

# Status bar
bar {
status_command ~/.local/bin/ch-os-status

    colors {
        background #050505
        statusline #BFFFE8
        separator  #4DFFAA

        focused_workspace  #4DFFAA #4DFFAA #000000
        active_workspace   #101414 #101414 #BFFFE8
        inactive_workspace #050505 #050505 #7EDDB8
        urgent_workspace   #ff6b6b #ff6b6b #ffffff
    }
}
# App hotkeys
bindsym $mod+c exec google-chrome


bindsym Print exec flameshot gui
bindsym $mod+u exec flameshot gui
bindsym $mod+Print exec flameshot full -p ~/Pictures

bindsym $mod+Shift+s exec simplescreenrecorder

# volume
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle

exec --no-startup-id blueman-applet

# telegram
exec --no-startup-id /usr/lib/x86_64-linux-gnu/xdg-desktop-portal
exec --no-startup-id /usr/lib/x86_64-linux-gnu/xdg-desktop-portal-gtk

# Brightness
bindsym F7 exec brightnessctl set 10%-
bindsym F8 exec brightnessctl set +10%


default_border pixel 2
default_floating_border pixel 2

client.focused          #4DFFAA #101414 #000000 #4DFFAA #4DFFAA
client.focused_inactive #1A2020 #1A2020 #AAAAAA #1A2020 #1A2020
client.unfocused        #101414 #101414 #888888 #101414 #101414
client.urgent           #ff6b6b #ff6b6b #ffffff #ff6b6b #ff6b6b


# assign [class="Firefox"] $ws2
# assign [class="TelegramDesktop"] $ws3
# assign [class="Code"] $ws1



# CH OS touchpad workspace gestures
bindsym $mod+comma workspace prev
bindsym $mod+period workspace next

# CH OS touchpad autostart
exec --no-startup-id pkill touchegg
exec --no-startup-id touchegg

bindsym XF86Launch4 exec ~/.local/bin/asus-profile-toggle

# exec --no-startup-id setxkbmap -layout "us,ru" -option "grp:alt_shift_toggle"


# Lang

exec --no-startup-id ibus-daemon -drx
exec --no-startup-id setxkbmap -layout us

# FIX: language switch
bindsym Mod4+space exec --no-startup-id ibus engine xkb:us::eng
bindsym Mod4+Shift+space exec --no-startup-id ibus engine m17n:ru:chos

# FIX: disable broken resize on Alt+r
# bindsym Mod1+r mode "resize"

# CH OS: every new normal window goes to max(workspace)+1
exec_always --no-startup-id pkill -f ch-os-auto-new-ws
exec_always --no-startup-id ~/.local/bin/ch-os-auto-new-ws



# CH OS safe binds
bindsym $mod+d exec --no-startup-id ~/.local/bin/appmenu
bindsym $mod+Escape exec --no-startup-id ~/.local/bin/chos-power

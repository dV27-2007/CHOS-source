#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)"
SOURCE_APP="$SCRIPT_DIR/../apps/chos-files/src/chos_files.py"
FALLBACK_APP="$HOME/Desktop/CHOS-source/apps/chos-files/src/chos_files.py"

if [ -f "$SOURCE_APP" ]; then
  APP_PATH="$SOURCE_APP"
elif [ -f "$FALLBACK_APP" ]; then
  APP_PATH="$FALLBACK_APP"
else
  printf 'CHOS Files launcher error: cannot find chos_files.py\n' >&2
  exit 1
fi

exec python3 "$APP_PATH" "$@"
